/* 地图页面样式 */
.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
}

.map-container {
  width: 100%;
  height: 100vh;
}

/* 底部信息面板 */
.bottom-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 20rpx 40rpx;
  z-index: 100;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.panel-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
}

.panel-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.panel-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.panel-desc {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.panel-location {
  font-size: 24rpx;
  color: #4A90D9;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.panel-time {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 统计浮层 */
.map-stats {
  position: fixed;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255, 255, 255, 0.95);
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
}

/* 空状态 */
.map-empty {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 50;
  background: rgba(255, 255, 255, 0.9);
  padding: 60rpx 48rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.map-empty .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.map-empty .empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.map-empty .empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* 定位按钮 */
.locate-btn {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  font-size: 36rpx;
}

.locate-btn:active {
  transform: scale(0.95);
}
