/* 图库页面样式 */
.gallery-page {
  padding-bottom: 40rpx;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.stats-text {
  font-size: 26rpx;
  color: #999;
}

/* 照片卡片 */
.photo-card {
  padding: 0;
  overflow: hidden;
}

.photo-images {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.photo-cover {
  width: 100%;
  height: 100%;
}

.photo-count {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 照片信息 */
.photo-info {
  padding: 20rpx 24rpx;
}

/* 用户信息 */
.photo-user {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.user-name {
  font-size: 26rpx;
  color: #4A90D9;
  font-weight: 500;
}

.photo-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.photo-desc-empty {
  color: #ccc;
  font-style: italic;
}

.photo-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.photo-location {
  font-size: 24rpx;
  color: #4A90D9;
}

.photo-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 操作按钮 */
.photo-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.action-btn:last-child {
  border-right: none;
}

.action-btn:active {
  background: #f5f5f5;
}

.action-delete {
  color: #e74c3c;
}
