/* 上传页面样式 */
.upload-page {
  padding-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 图片选择器 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 12rpx;
}

.add-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
  background: #fafafa;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 22rpx;
  color: #999;
}

/* 位置信息 */
.location-info {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.location-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.location-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.location-address {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.location-coords {
  font-size: 22rpx;
  color: #999;
}

.location-placeholder {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.location-hint {
  font-size: 22rpx;
  color: #bbb;
}

.location-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 12rpx;
}

/* 描述输入 */
.desc-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 12rpx 0;
}

/* 上传按钮 */
.upload-btn {
  margin-top: 40rpx;
  width: 100% !important;
}

.upload-btn[disabled] {
  background: #ccc;
  color: #fff;
}
